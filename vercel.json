{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "prepamedecine-site.vercel.app"
        }
      ],
      "destination": "https://prepamedecine.fr/$1",
      "permanent": true
    },
    { "source": "/index.php/diploma-sante/:path*", "destination": "/#diploma-sante", "permanent": true },
    { "source": "/index.php/biomedal/:path*", "destination": "/#biomedal", "permanent": true },
    { "source": "/index.php/medisup/:path*", "destination": "/#medisup", "permanent": true },
    { "source": "/index.php/medschool/:path*", "destination": "/#medschool", "permanent": true },
    { "source": "/index.php/antemed-epsilon/:path*", "destination": "/#antemed-epsilon", "permanent": true },
    { "source": "/index.php/prepas/:path*", "destination": "/#prepas", "permanent": true },
    { "source": "/index.php/pass-ou-las/:path*", "destination": "/pass-ou-las/", "permanent": true },
    { "source": "/index.php/:path*", "destination": "/", "permanent": true }
  ]
}
